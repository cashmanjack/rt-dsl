#include <optix.h>
#include <optix_stubs.h>
#include <optix_function_table_definition.h>
#include <cuda_runtime.h>
#include <iostream>
#include <vector>
#include <string>
#include <cstring>
#include <unordered_map>
#include <mutex>

#define CUDA_CHECK(call) \
    do { \
        cudaError_t err = call; \
        if (err != cudaSuccess) { \
            fprintf(stderr, "CUDA Error: %s at line %d\n", cudaGetErrorString(err), __LINE__); \
            exit(EXIT_FAILURE); \
        } \
    } while (0)

#define OPTIX_CHECK(call) \
    do { \
        OptixResult res = call; \
        if (res != OPTIX_SUCCESS) { \
            fprintf(stderr, "Optix Error: %d at line %d\n", res, __LINE__); \
            exit(EXIT_FAILURE); \
        } \
    } while (0)

static void context_log_cb(unsigned int level, const char* tag, const char* message, void* cbdata) {
    if (level <= 3) fprintf(stderr, "[OptiX LOG]: %s\n", message);
}

struct __align__(OPTIX_SBT_RECORD_ALIGNMENT) SbtRecord {
    char header[OPTIX_SBT_RECORD_HEADER_SIZE];
};

struct CGprtPipeline {
    OptixDeviceContext context;
    OptixModule module;
    OptixPipeline pipeline;
    OptixShaderBindingTable sbt;
    cudaStream_t stream;
    
    void* d_raygen_rec;
    void* d_miss_rec;
    void* d_hitgroup_rec;

    std::unordered_map<std::string, void*> d_arrays;
    std::unordered_map<std::string, void*> d_lens;
    std::unordered_map<std::string, unsigned int> caps;
    std::unordered_map<std::string, void*> d_values;
    
    void* d_params;
    void* d_bundle; 
    void* d_rays;

    void* d_geom;
    bool is_hw_triangle;
};

struct CGprtBvh {
    OptixTraversableHandle handle;
    void* d_buffer;
    void* d_temp;
    void* d_aabbs;
    size_t temp_size;
    size_t output_size;
};

struct PayloadBundle {
    unsigned long long dyn_ptrs[8];
    unsigned int dyn_caps[8];
    unsigned long long dyn_lens[8];
    unsigned long long val_ptrs[8];
};

struct LaunchParams {
    OptixTraversableHandle handle;
    float4* rays;
    int num_rays;
    PayloadBundle* bundle;
    float4* geom;
};

struct NodeSpatial { float3 com; float mass; };
struct NodeRouting { unsigned int next_idx; unsigned int autorope; unsigned int is_leaf; float width; unsigned int bucket_start; unsigned int num_particles; unsigned int _pad[2]; };
struct Body { float3 pos; float mass; float3 velocity; };

struct AutoropeLaunchParams {
    OptixTraversableHandle handle;
    Body* bodies; int num_bodies; int num_nodes;
    NodeSpatial* tree_spatial; NodeRouting* tree_routing;
    float3* out_forces; float theta;
    unsigned int* debug_hits; unsigned int* debug_misses; unsigned int* debug_depth;
};

extern "C" {




// 2. Add this FFI function inside the extern "C" block
void gprt_bvh_refit_spheres_gpu(CGprtPipeline* pipe, CGprtBvh* bvh, float radius, int count) {
    // Launch kernel to update AABBs directly in VRAM
    int threads = 256;
    int blocks = (count + threads - 1) / threads;
    compute_sphere_aabbs_kernel<<<blocks, threads, 0, pipe->stream>>>((float4*)pipe->d_geom, (float*)bvh->d_aabbs, radius, count);
    
    // Trigger OptiX Refit using the freshly generated VRAM AABBs
    OptixBuildInput buildInput = {};
    buildInput.type = OPTIX_BUILD_INPUT_TYPE_CUSTOM_PRIMITIVES;
    CUdeviceptr d_aabb_ptr = (CUdeviceptr)bvh->d_aabbs;
    buildInput.customPrimitiveArray.aabbBuffers = &d_aabb_ptr;
    buildInput.customPrimitiveArray.numPrimitives = count;
    buildInput.customPrimitiveArray.strideInBytes = 6 * sizeof(float);
    static unsigned int refit_flags[1] = { OPTIX_GEOMETRY_FLAG_NONE };
    buildInput.customPrimitiveArray.flags = refit_flags;
    buildInput.customPrimitiveArray.numSbtRecords = 1;

    OptixAccelBuildOptions accelOptions = {};
    accelOptions.buildFlags = OPTIX_BUILD_FLAG_ALLOW_UPDATE | OPTIX_BUILD_FLAG_PREFER_FAST_TRACE;
    accelOptions.operation = OPTIX_BUILD_OPERATION_UPDATE;

    OPTIX_CHECK(optixAccelBuild(pipe->context, pipe->stream, &accelOptions, &buildInput, 1,
        (CUdeviceptr)bvh->d_temp, bvh->temp_size,
        (CUdeviceptr)bvh->d_buffer, bvh->output_size,
        &bvh->handle, nullptr, 0));
    cudaStreamSynchronize(pipe->stream);
}


CGprtPipeline* gprt_pipeline_create(const void* ir_data, size_t ir_size, int is_hw_triangle) {
    cudaFree(0); 
    OPTIX_CHECK(optixInit());
    
    CGprtPipeline* pipe = new CGprtPipeline();
    pipe->is_hw_triangle = (is_hw_triangle != 0);
    CUDA_CHECK(cudaStreamCreate(&pipe->stream));

    OptixDeviceContextOptions options = {};
    options.logCallbackFunction = context_log_cb;
    options.logCallbackLevel = 3;
    OPTIX_CHECK(optixDeviceContextCreate(0, &options, &pipe->context));

    OptixModuleCompileOptions moduleCompileOptions = {};
    OptixPipelineCompileOptions pipelineCompileOptions = {};
    pipelineCompileOptions.traversableGraphFlags = OPTIX_TRAVERSABLE_GRAPH_FLAG_ALLOW_SINGLE_GAS;
    pipelineCompileOptions.numPayloadValues = 4;
    pipelineCompileOptions.numAttributeValues = 2;
    pipelineCompileOptions.pipelineLaunchParamsVariableName = "params";
    pipelineCompileOptions.usesMotionBlur = 0;

    OPTIX_CHECK(optixModuleCreate(pipe->context, &moduleCompileOptions, &pipelineCompileOptions, (const char*)ir_data, ir_size, nullptr, nullptr, &pipe->module));

    OptixProgramGroupOptions programGroupOptions = {};
    OptixProgramGroup raygenGroup, missGroup, hitGroup;

    OptixProgramGroupDesc raygenDesc = {};
    raygenDesc.kind = OPTIX_PROGRAM_GROUP_KIND_RAYGEN;
    raygenDesc.raygen.module = pipe->module;
    raygenDesc.raygen.entryFunctionName = "__raygen__rg";
    OPTIX_CHECK(optixProgramGroupCreate(pipe->context, &raygenDesc, 1, &programGroupOptions, nullptr, nullptr, &raygenGroup));

    OptixProgramGroupDesc missDesc = {};
    missDesc.kind = OPTIX_PROGRAM_GROUP_KIND_MISS;
    missDesc.miss.module = pipe->module;
    missDesc.miss.entryFunctionName = "__miss__ms";
    OPTIX_CHECK(optixProgramGroupCreate(pipe->context, &missDesc, 1, &programGroupOptions, nullptr, nullptr, &missGroup));

    OptixProgramGroupDesc hitDesc = {};
    hitDesc.kind = OPTIX_PROGRAM_GROUP_KIND_HITGROUP;
    hitDesc.hitgroup.moduleAH = pipe->module;
    hitDesc.hitgroup.entryFunctionNameAH = "__anyhit__ah";
    hitDesc.hitgroup.moduleCH = pipe->module;
    hitDesc.hitgroup.entryFunctionNameCH = "__closesthit__ch";
    if (!pipe->is_hw_triangle) {
        hitDesc.hitgroup.moduleIS = pipe->module;
        hitDesc.hitgroup.entryFunctionNameIS = "__intersection__is";
    }
    OPTIX_CHECK(optixProgramGroupCreate(pipe->context, &hitDesc, 1, &programGroupOptions, nullptr, nullptr, &hitGroup));

    OptixProgramGroup groups[] = { raygenGroup, missGroup, hitGroup };
    OptixPipelineLinkOptions linkOptions = {};
    linkOptions.maxTraceDepth = 1;
    OPTIX_CHECK(optixPipelineCreate(pipe->context, &pipelineCompileOptions, &linkOptions, groups, 3, nullptr, nullptr, &pipe->pipeline));

    SbtRecord h_raygen_rec, h_miss_rec, h_hitgroup_rec;
    OPTIX_CHECK(optixSbtRecordPackHeader(raygenGroup, &h_raygen_rec));
    OPTIX_CHECK(optixSbtRecordPackHeader(missGroup, &h_miss_rec));
    OPTIX_CHECK(optixSbtRecordPackHeader(hitGroup, &h_hitgroup_rec));

    CUDA_CHECK(cudaMalloc(&pipe->d_raygen_rec, sizeof(SbtRecord)));
    CUDA_CHECK(cudaMalloc(&pipe->d_miss_rec, sizeof(SbtRecord)));
    CUDA_CHECK(cudaMalloc(&pipe->d_hitgroup_rec, sizeof(SbtRecord)));

    CUDA_CHECK(cudaMemcpy(pipe->d_raygen_rec, &h_raygen_rec, sizeof(SbtRecord), cudaMemcpyHostToDevice));
    CUDA_CHECK(cudaMemcpy(pipe->d_miss_rec, &h_miss_rec, sizeof(SbtRecord), cudaMemcpyHostToDevice));
    CUDA_CHECK(cudaMemcpy(pipe->d_hitgroup_rec, &h_hitgroup_rec, sizeof(SbtRecord), cudaMemcpyHostToDevice));

    pipe->sbt.raygenRecord = (CUdeviceptr)pipe->d_raygen_rec;
    pipe->sbt.missRecordBase = (CUdeviceptr)pipe->d_miss_rec;
    pipe->sbt.missRecordStrideInBytes = sizeof(SbtRecord);
    pipe->sbt.missRecordCount = 1;
    pipe->sbt.hitgroupRecordBase = (CUdeviceptr)pipe->d_hitgroup_rec;
    pipe->sbt.hitgroupRecordStrideInBytes = sizeof(SbtRecord);
    pipe->sbt.hitgroupRecordCount = 1;

    CUDA_CHECK(cudaMalloc(&pipe->d_params, sizeof(LaunchParams)));
    CUDA_CHECK(cudaMalloc(&pipe->d_bundle, sizeof(PayloadBundle))); 
    return pipe;
}

void gprt_pipeline_destroy(CGprtPipeline* pipe) {
    if (!pipe) return;
    // FIXED: Host pinned memory allocated with cudaHostAlloc must be freed with cudaFreeHost
    for (auto& p : pipe->d_arrays) cudaFreeHost(p.second);
    for (auto& p : pipe->d_lens) cudaFreeHost(p.second);
    for (auto& p : pipe->d_values) cudaFreeHost(p.second);
    if (pipe->d_params) cudaFree(pipe->d_params);
    if (pipe->d_bundle) cudaFree(pipe->d_bundle);
    if (pipe->d_rays) cudaFree(pipe->d_rays);
    if (pipe->d_raygen_rec) cudaFree(pipe->d_raygen_rec);
    if (pipe->d_miss_rec) cudaFree(pipe->d_miss_rec);
    if (pipe->d_hitgroup_rec) cudaFree(pipe->d_hitgroup_rec);
    if (pipe->pipeline) optixPipelineDestroy(pipe->pipeline);
    if (pipe->module) optixModuleDestroy(pipe->module);
    if (pipe->context) optixDeviceContextDestroy(pipe->context);
    cudaStreamDestroy(pipe->stream);
    delete pipe;
}

CGprtBvh* gprt_bvh_build(CGprtPipeline* pipe, const float* h_geom, const float* h_aabbs, int count, int geom_bytes, int build_flag) {
    cudaEvent_t start, stop;
    cudaEventCreate(&start); cudaEventCreate(&stop);
    cudaEventRecord(start, pipe->stream);

    CGprtBvh* bvh = new CGprtBvh();
    CUDA_CHECK(cudaMalloc(&bvh->d_aabbs, count * 6 * sizeof(float)));
    CUDA_CHECK(cudaMemcpyAsync(bvh->d_aabbs, h_aabbs, count * 6 * sizeof(float), cudaMemcpyHostToDevice, pipe->stream));

    if (geom_bytes > 0 && h_geom != nullptr) {
        if (pipe->d_geom) cudaFree(pipe->d_geom);
        CUDA_CHECK(cudaMalloc(&pipe->d_geom, geom_bytes));
        CUDA_CHECK(cudaMemcpyAsync(pipe->d_geom, h_geom, geom_bytes, cudaMemcpyHostToDevice, pipe->stream));
    }

    OptixBuildInput buildInput = {};
    buildInput.type = OPTIX_BUILD_INPUT_TYPE_CUSTOM_PRIMITIVES;
    
    CUdeviceptr d_aabb_ptr = (CUdeviceptr)bvh->d_aabbs;
    buildInput.customPrimitiveArray.aabbBuffers = &d_aabb_ptr;
    buildInput.customPrimitiveArray.numPrimitives = count;
    buildInput.customPrimitiveArray.strideInBytes = 6 * sizeof(float);
    
    static unsigned int build_flags[1] = { OPTIX_GEOMETRY_FLAG_NONE };
    buildInput.customPrimitiveArray.flags = build_flags;
    buildInput.customPrimitiveArray.numSbtRecords = 1;

    OptixAccelBuildOptions accelOptions = {};
    accelOptions.operation = OPTIX_BUILD_OPERATION_BUILD;
    
    unsigned int flags = OPTIX_BUILD_FLAG_ALLOW_UPDATE;
    if (build_flag == 0) {
        flags |= OPTIX_BUILD_FLAG_PREFER_FAST_TRACE; 
    } else {
        flags |= OPTIX_BUILD_FLAG_PREFER_FAST_BUILD; 
    }
    accelOptions.buildFlags = flags;

    OptixAccelBufferSizes gasBufferSizes;
    OPTIX_CHECK(optixAccelComputeMemoryUsage(pipe->context, &accelOptions, &buildInput, 1, &gasBufferSizes));

    CUDA_CHECK(cudaMalloc(&bvh->d_temp, gasBufferSizes.tempSizeInBytes));
    CUDA_CHECK(cudaMalloc(&bvh->d_buffer, gasBufferSizes.outputSizeInBytes));

    bvh->temp_size = gasBufferSizes.tempSizeInBytes;
    bvh->output_size = gasBufferSizes.outputSizeInBytes;

    OPTIX_CHECK(optixAccelBuild(pipe->context, pipe->stream, &accelOptions, &buildInput, 1, 
                                (CUdeviceptr)bvh->d_temp, gasBufferSizes.tempSizeInBytes, 
                                (CUdeviceptr)bvh->d_buffer, gasBufferSizes.outputSizeInBytes, 
                                &bvh->handle, nullptr, 0));

    cudaEventRecord(stop, pipe->stream);
    cudaEventSynchronize(stop);
    float ms = 0; cudaEventElapsedTime(&ms, start, stop);
    printf("[CUDA_EVENTS] bvh_build=%.3fms (build_flag=%d)\n", ms, build_flag);
    cudaEventDestroy(start); cudaEventDestroy(stop);

    return bvh;
}

CGprtBvh* gprt_bvh_build_triangles(CGprtPipeline* pipe, const float* h_verts, const unsigned int* h_indices, int num_triangles, const float* h_aabbs, int build_flag) {
    return gprt_bvh_build(pipe, h_verts, h_aabbs, num_triangles, 0, build_flag); 
}

void gprt_bvh_refit(CGprtPipeline* pipe, CGprtBvh* bvh, const float* h_aabbs, int count) {
    cudaEvent_t start, stop;
    cudaEventCreate(&start); cudaEventCreate(&stop);
    cudaEventRecord(start, pipe->stream);

    CUDA_CHECK(cudaMemcpyAsync(bvh->d_aabbs, h_aabbs, count * 6 * sizeof(float), cudaMemcpyHostToDevice, pipe->stream));

    OptixBuildInput buildInput = {};
    buildInput.type = OPTIX_BUILD_INPUT_TYPE_CUSTOM_PRIMITIVES;
    
    CUdeviceptr d_aabb_ptr = (CUdeviceptr)bvh->d_aabbs;
    buildInput.customPrimitiveArray.aabbBuffers = &d_aabb_ptr;
    buildInput.customPrimitiveArray.numPrimitives = count;
    buildInput.customPrimitiveArray.strideInBytes = 6 * sizeof(float);
    
    static unsigned int refit_flags[1] = { OPTIX_GEOMETRY_FLAG_NONE };
    buildInput.customPrimitiveArray.flags = refit_flags;
    buildInput.customPrimitiveArray.numSbtRecords = 1;

    OptixAccelBuildOptions accelOptions = {};
    accelOptions.buildFlags = OPTIX_BUILD_FLAG_ALLOW_UPDATE;
    accelOptions.operation = OPTIX_BUILD_OPERATION_UPDATE;

    OPTIX_CHECK(optixAccelBuild(pipe->context, pipe->stream, &accelOptions, &buildInput, 1, 
                                (CUdeviceptr)bvh->d_temp, bvh->temp_size, 
                                (CUdeviceptr)bvh->d_buffer, bvh->output_size, 
                                &bvh->handle, nullptr, 0));

    cudaEventRecord(stop, pipe->stream);
    cudaEventSynchronize(stop);
    float ms = 0; cudaEventElapsedTime(&ms, start, stop);
    printf("[CUDA_EVENTS] bvh_refit=%.3fms\n", ms);
    cudaEventDestroy(start); cudaEventDestroy(stop);
}

void gprt_bvh_destroy(CGprtBvh* bvh) {
    if (!bvh) return;
    if (bvh->d_buffer) cudaFree(bvh->d_buffer);
    if (bvh->d_temp) cudaFree(bvh->d_temp);
    if (bvh->d_aabbs) cudaFree(bvh->d_aabbs);
    delete bvh;
}

void gprt_register_array(CGprtPipeline* pipe, const char* name, unsigned int capacity_per_query, int num_queries) {
    std::string s_name(name);
    if (pipe->d_arrays.count(s_name)) cudaFreeHost(pipe->d_arrays[s_name]);
    if (pipe->d_lens.count(s_name)) cudaFreeHost(pipe->d_lens[s_name]);

    size_t total_elements = (size_t)capacity_per_query * num_queries;
    
    // EXPOSED: Allocates direct Zero-Copy Host Pinned memory mapped to GPU space
    CUDA_CHECK(cudaHostAlloc(&pipe->d_arrays[s_name], total_elements * sizeof(unsigned int), cudaHostAllocMapped));
    CUDA_CHECK(cudaHostAlloc(&pipe->d_lens[s_name], num_queries * sizeof(unsigned int), cudaHostAllocMapped));
    
    memset(pipe->d_lens[s_name], 0, num_queries * sizeof(unsigned int));
    pipe->caps[s_name] = capacity_per_query;
}

void gprt_register_value(CGprtPipeline* pipe, const char* name) {
    std::string s_name(name);
    if (pipe->d_values.count(s_name)) cudaFreeHost(pipe->d_values[s_name]);
    CUDA_CHECK(cudaHostAlloc(&pipe->d_values[s_name], sizeof(unsigned int), cudaHostAllocMapped));
}

void gprt_execute(CGprtPipeline* pipe, CGprtBvh* bvh, const float* h_queries, int count) {
    cudaEvent_t start, stop;
    cudaEventCreate(&start); cudaEventCreate(&stop);

    if (!pipe->d_rays) CUDA_CHECK(cudaMalloc(&pipe->d_rays, count * 4 * sizeof(float)));
    CUDA_CHECK(cudaMemcpyAsync(pipe->d_rays, h_queries, count * 4 * sizeof(float), cudaMemcpyHostToDevice, pipe->stream));

    PayloadBundle bundle = {};
    if (!pipe->d_arrays.empty()) {
        auto it = pipe->d_arrays.begin();
        
        // Zero-copy addresses directly passed to shader bindings
        CUDA_CHECK(cudaHostGetDevicePointer((void**)&bundle.dyn_ptrs[0], pipe->d_arrays[it->first], 0));
        bundle.dyn_caps[0] = pipe->caps[it->first];
        CUDA_CHECK(cudaHostGetDevicePointer((void**)&bundle.dyn_lens[0], pipe->d_lens[it->first], 0));
    }
    
    CUDA_CHECK(cudaMemcpyAsync(pipe->d_bundle, &bundle, sizeof(PayloadBundle), cudaMemcpyHostToDevice, pipe->stream));

    LaunchParams params = { bvh->handle, (float4*)pipe->d_rays, count, (PayloadBundle*)pipe->d_bundle, (float4*)pipe->d_geom };
    CUDA_CHECK(cudaMemcpyAsync(pipe->d_params, &params, sizeof(LaunchParams), cudaMemcpyHostToDevice, pipe->stream));

    cudaEventRecord(start, pipe->stream);
    OPTIX_CHECK(optixLaunch(pipe->pipeline, pipe->stream, (CUdeviceptr)pipe->d_params, sizeof(LaunchParams), &pipe->sbt, count, 1, 1));
    cudaEventRecord(stop, pipe->stream);
    cudaEventSynchronize(stop);
    
    float ms = 0; cudaEventElapsedTime(&ms, start, stop);
    printf("[CUDA_EVENTS] kernel=%.3fms\n", ms);
    
    cudaEventDestroy(start); cudaEventDestroy(stop);
}

void gprt_retrieve_array_lengths(CGprtPipeline* pipe, const char* name, unsigned int* h_lengths, int num_queries) {
    cudaEvent_t start, stop;
    cudaEventCreate(&start); cudaEventCreate(&stop);
    cudaEventRecord(start, pipe->stream);

    // OPTIMIZATION: Host-pinned memory allows CPU-side fast memcpy instead of device copies
    memcpy(h_lengths, pipe->d_lens[name], num_queries * sizeof(unsigned int));
    
    cudaEventRecord(stop, pipe->stream);
    cudaEventSynchronize(stop);
    float ms = 0; cudaEventElapsedTime(&ms, start, stop);
    printf("[CUDA_EVENTS] memcpy_lens=%.3fms\n", ms);
    cudaEventDestroy(start); cudaEventDestroy(stop);
}

void gprt_retrieve_array_flat(CGprtPipeline* pipe, const char* name, unsigned int* h_out, int total_elements) {
    cudaEvent_t start, stop;
    cudaEventCreate(&start); cudaEventCreate(&stop);
    cudaEventRecord(start, pipe->stream);

    // OPTIMIZATION: Zero PCIe delay copies via fast host-pinned mappings
    memcpy(h_out, pipe->d_arrays[name], total_elements * sizeof(unsigned int));
    
    cudaEventRecord(stop, pipe->stream);
    cudaEventSynchronize(stop);
    float ms = 0; cudaEventElapsedTime(&ms, start, stop);
    printf("[CUDA_EVENTS] memcpy_flat=%.3fms\n", ms);
    cudaEventDestroy(start); cudaEventDestroy(stop);
}

void gprt_retrieve_value(CGprtPipeline* pipe, const char* name, unsigned int* h_out) {
    memcpy(h_out, pipe->d_values[name], sizeof(unsigned int));
}

void gprt_execute_autorope_soa_ffi(
    CGprtPipeline* pipe, const void* h_bodies, int num_bodies, 
    const void* h_spatial, int num_nodes, const void* h_routing, 
    float theta, void* h_out_forces
) {
    cudaEvent_t start, stop;
    cudaEventCreate(&start); cudaEventCreate(&stop);

    void *d_bodies, *d_spatial, *d_routing, *d_out_forces;
    unsigned int *d_hits, *d_misses, *d_depth;
    CUDA_CHECK(cudaMalloc(&d_bodies, num_bodies * sizeof(Body)));
    CUDA_CHECK(cudaMalloc(&d_spatial, num_nodes * sizeof(NodeSpatial)));
    CUDA_CHECK(cudaMalloc(&d_routing, num_nodes * sizeof(NodeRouting)));
    CUDA_CHECK(cudaMalloc(&d_out_forces, num_bodies * sizeof(float3)));
    CUDA_CHECK(cudaMalloc(&d_hits, sizeof(unsigned int))); CUDA_CHECK(cudaMemset(d_hits, 0, sizeof(unsigned int)));
    CUDA_CHECK(cudaMalloc(&d_misses, sizeof(unsigned int))); CUDA_CHECK(cudaMemset(d_misses, 0, sizeof(unsigned int)));
    CUDA_CHECK(cudaMalloc(&d_depth, sizeof(unsigned int))); CUDA_CHECK(cudaMemset(d_depth, 0, sizeof(unsigned int)));

    CUDA_CHECK(cudaMemcpyAsync(d_bodies, h_bodies, num_bodies * sizeof(Body), cudaMemcpyHostToDevice, pipe->stream));
    CUDA_CHECK(cudaMemcpyAsync(d_spatial, h_spatial, num_nodes * sizeof(NodeSpatial), cudaMemcpyHostToDevice, pipe->stream));
    CUDA_CHECK(cudaMemcpyAsync(d_routing, h_routing, num_nodes * sizeof(NodeRouting), cudaMemcpyHostToDevice, pipe->stream));

    AutoropeLaunchParams params = { 0, (Body*)d_bodies, num_bodies, num_nodes, (NodeSpatial*)d_spatial, (NodeRouting*)d_routing, (float3*)d_out_forces, theta, d_hits, d_misses, d_depth };
    CUDA_CHECK(cudaMemcpyAsync(pipe->d_params, &params, sizeof(AutoropeLaunchParams), cudaMemcpyHostToDevice, pipe->stream));

    cudaEventRecord(start, pipe->stream);
    OPTIX_CHECK(optixLaunch(pipe->pipeline, pipe->stream, (CUdeviceptr)pipe->d_params, sizeof(AutoropeLaunchParams), &pipe->sbt, num_bodies, 1, 1));
    cudaEventRecord(stop, pipe->stream);
    cudaEventSynchronize(stop);
    
    float ms = 0; cudaEventElapsedTime(&ms, start, stop);
    printf("[CUDA_EVENTS] autorope_kernel=%.3fms\n", ms);

    CUDA_CHECK(cudaMemcpy(h_out_forces, d_out_forces, num_bodies * sizeof(float3), cudaMemcpyDeviceToHost));

    unsigned int h_hits, h_misses, h_depth;
    CUDA_CHECK(cudaMemcpy(&h_hits, d_hits, sizeof(unsigned int), cudaMemcpyDeviceToHost));
    CUDA_CHECK(cudaMemcpy(&h_misses, d_misses, sizeof(unsigned int), cudaMemcpyDeviceToHost));
    CUDA_CHECK(cudaMemcpy(&h_depth, d_depth, sizeof(unsigned int), cudaMemcpyDeviceToHost));
    printf("[DEBUG GPU] Total Hits: %u | Total Misses: %u | Avg Depth: %f\n", h_hits, h_misses, (float)h_depth / num_bodies);

    cudaFree(d_bodies); cudaFree(d_spatial); cudaFree(d_routing); cudaFree(d_out_forces);
    cudaFree(d_hits); cudaFree(d_misses); cudaFree(d_depth);
    cudaEventDestroy(start); cudaEventDestroy(stop);
}

} // extern "C"
